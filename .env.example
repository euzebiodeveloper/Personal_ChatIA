# ──────────────────────────────────────────────────────────────
# AI Assistant — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.
# ──────────────────────────────────────────────────────────────

# Groq API key — modelos de texto + último fallback de visão (llama-4-scout)
# https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API key (PRINCIPAL para visão — qwen3.6-plus:free, grátis sem limite documentado)
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini API key (2º fallback de visão — Gemini 2.5 Flash, ~1500 req/dia grátis)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx
